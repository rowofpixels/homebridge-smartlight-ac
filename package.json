{
  "name": "homebridge-smartlight-ac",
  "version": "0.1.6",
  "description": "Homebridge plugin for Smartlight SLWF-01pro ESPHome AC controllers",
  "license": "ISC",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": "^20.18.0 || ^22.10.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0-beta.0"
  },
  "keywords": [
    "homebridge-plugin",
    "esphome",
    "smartlight",
    "slwf-01pro",
    "midea",
    "mr-cool",
    "air-conditioner",
    "hvac"
  ],
  "scripts": {
    "build": "rimraf ./dist && tsc",
